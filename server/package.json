{
  "name": "resume-matcher",
  "version": "1.0.0",
  "description": "Rule-based Resume Parsing and Job Matching System — No LLMs",
  "main": "src/server.js",
  "type":"module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:ui": "cd client && npm install && npm run build",
    "dev:ui": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ui\""
  },
  "keywords": ["resume", "job-matching", "nlp", "rule-based"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mammoth": "^1.7.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}